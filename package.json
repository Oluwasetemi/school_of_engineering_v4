{
  "name": "school_of_engineering_v4",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "npx playwright-core install chromium",
    "build": "cross-env NODE_OPTIONS='--openssl-legacy-provider --max_old_space_size=8192' slidev build --timeout 60000",
    "build:netlify": "cross-env NODE_ENV=production NODE_OPTIONS='--openssl-legacy-provider --max_old_space_size=4096' slidev build --timeout 60000",
    "dev": "nodemon -e 'md,js,mjs,cjs,json' -w '../../packages/slidev/dist/*.mjs' --exec \"slidev ./slides.md --open=false --log=info --inspect\"",
    "export": "slidev export",
    "export:pdf": "npm run export -- --timeout 160000 --with-toc --output ./_export/soe_altschool_semester1.pdf",
    "export:pptx": "npm run export -- --timeout 160000 --with-clicks false --format pptx --output ./_export/soe_altschool_semester1.pptx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@slidev/cli": "52.15.1",
    "@slidev/client": "^52.15.1",
    "@slidev/theme-default": "latest",
    "@vueuse/core": "^14.3.0",
    "markdown-it-magic-link": "^0.1.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@babel/standalone": "^7.29.3",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/mdi": "^1.2.3",
    "@slidev/types": "52.15.1",
    "@vue/compiler-sfc": "^3.5.33",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.14",
    "playwright-chromium": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-slidev": "^1.0.5"
  },
  "license": "MIT"
}
